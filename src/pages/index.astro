    <a href="/products/pp-interlocking-tiles" class="mobile-nav-link">PP Interlocking Tiles</a>
    <a href="/products/epdm-tracks-surfaces" class="mobile-nav-link">EPDM Tracks &amp; Surfaces</a>
    <a href="/products/acrylic-court-systems" class="mobile-nav-link">Acrylic Court Systems</a>
    <a href="/products/badminton-pvc-vinyl-sports-flooring" class="mobile-nav-link">Badminton PVC Vinyl Sports Flooring</a>
    <a href="/products/badminton-wooden-flooring" class="mobile-nav-link">Badminton Wooden Flooring (Teakwood &amp; Canadian Maple Wood)</a>
