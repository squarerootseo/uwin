      <a href="https://wa.me/919311818112" target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp Us Now
      </a>
    </div>
  </div>

  <!-- ============================================================
       HERO SECTION, Full-bleed photorealistic background
       ============================================================ -->
  <section id="hero" aria-label="Hero">

    <!-- Full-bleed background images (cycle via JS) -->
    <div class="hero-bg active" id="heroBg0" style="background-image: url('images/hero-pp-tiles.png');"></div>
    <div class="hero-bg" id="heroBg1" style="background-image: url('images/hero-acrylic.png');"></div>
    <div class="hero-bg" id="heroBg2" style="background-image: url('images/hero-epdm.png');"></div>

    <!-- Dark gradient overlay for text readability -->
    <div class="hero-overlay" aria-hidden="true"></div>

    <!-- Floating particles -->
    <div id="heroParticles" class="hero-particles" aria-hidden="true"></div>

    <!-- Content -->
    <div class="hero-inner">
      <div class="hero-left">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-dot"></span>
          <span>Turnkey Solutions &nbsp;&middot;&nbsp; ITF Certified &nbsp;&middot;&nbsp; Pan-India</span>
        </div>

        <h1 class="hero-title" id="heroTitle">Turnkey Sports Flooring Solutions for Schools, Developers &amp; Sports Clubs</h1>

        <p class="hero-subtitle" id="heroSubtitle">From idea to complete execution. From bare land to a ready-to-play court.</p>

        <div class="hero-ctas">
          <a href="/contact" class="btn btn-primary btn-lg" id="heroQuoteBtn">
            <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Get a Free Quote
          </a>
          <a href="https://wa.me/919311818112" target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg" id="heroWhatsAppBtn">
            <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us Now
          </a>
        </div>

        <div class="hero-badges" aria-label="Trust signals">
          <span class="trust-badge" style="animation-delay:600ms">
            <span class="trust-badge-check" aria-hidden="true">
              <svg width="9" height="9" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            ITF Certified Materials
          </span>
          <span class="trust-badge" style="animation-delay:720ms">
            <span class="trust-badge-check" aria-hidden="true">
              <svg width="9" height="9" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Competitive Direct Pricing
          </span>
          <span class="trust-badge" style="animation-delay:840ms">
            <span class="trust-badge-check" aria-hidden="true">
              <svg width="9" height="9" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            End-to-End Project Execution
          </span>
          <span class="trust-badge" style="animation-delay:960ms">
            <span class="trust-badge-check" aria-hidden="true">
              <svg width="9" height="9" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            Pan-India Projects
          </span>
        </div>
      </div>

      <!-- Guided-line product annotation, positioned absolutely within container -->
      <div class="hero-annotation" id="heroProductChip" aria-live="polite">
        <div class="annotation-track">
          <span class="annotation-dot" aria-hidden="true">
            <span class="annotation-dot-ring"></span>
          </span>
          <span class="annotation-line" aria-hidden="true"></span>
        </div>
        <div class="annotation-box">
          <span class="annotation-eyebrow">Now Viewing</span>
          <span class="annotation-name" id="heroChipLabel">PP Interlocking Modular Tiles</span>
        </div>
      </div>

    </div>

    <!-- Dot navigation, bottom centre -->
    <div class="hero-dot-nav" aria-label="Select product surface">
      <button class="hero-dot active" id="heroDot0" aria-label="PP Interlocking Tiles"></button>
      <button class="hero-dot" id="heroDot1" aria-label="Acrylic Court System"></button>
      <button class="hero-dot" id="heroDot2" aria-label="EPDM Athletic Track"></button>
    </div>

  </section>

  <!-- ============================================================
       SECTION 1.3, PRODUCT LINES OVERVIEW
       ============================================================ -->
  <section id="products" class="section section--surface">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="h2">From Bare Land to Ready-to-Play. Across India.</h2>
        <span class="section-divider" aria-hidden="true"></span>
        <p class="snapshot">
          Six premium surface systems sourced from certified producers. One team handles everything: site assessment, material supply, installation, and line marking. From idea to complete execution.
        </p>
      </div>

      <!-- Product Accordion -->
      <div class="product-accordion" role="list">

        <!-- ── Panel 1: PP Tiles ── -->
        <div class="pac-panel reveal reveal-delay-1" role="listitem">
          <input type="checkbox" id="pac1" class="pac-toggle" aria-hidden="true" />
          <label class="pac-header" for="pac1" role="button" aria-expanded="true" aria-controls="pac1-body">
            <span class="pac-icon pac-icon--green" aria-hidden="true">
              <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="3" y="3" width="15" height="15" rx="2" fill="#5BBE0F" opacity="0.15" stroke="#5BBE0F" stroke-width="1.4"/>
                <rect x="22" y="3" width="15" height="15" rx="2" fill="#5BBE0F" opacity="0.15" stroke="#5BBE0F" stroke-width="1.4"/>
                <rect x="3" y="22" width="15" height="15" rx="2" fill="#5BBE0F" opacity="0.15" stroke="#5BBE0F" stroke-width="1.4"/>
                <rect x="22" y="22" width="15" height="15" rx="2" fill="#5BBE0F" opacity="0.15" stroke="#5BBE0F" stroke-width="1.4"/>
                <rect x="18" y="8" width="4" height="4" rx="1" fill="#5BBE0F" opacity="0.7"/>
                <rect x="18" y="28" width="4" height="4" rx="1" fill="#5BBE0F" opacity="0.7"/>
                <rect x="8" y="18" width="4" height="4" rx="1" fill="#5BBE0F" opacity="0.7"/>
                <rect x="28" y="18" width="4" height="4" rx="1" fill="#5BBE0F" opacity="0.7"/>
                <circle cx="20" cy="20" r="2" fill="#5BBE0F"/>
              </svg>
            </span>
            <span class="pac-title-wrap">
              <span class="pac-eyebrow">Surface System 01</span>
              <span class="pac-title">PP Interlocking Modular Tiles</span>
            </span>
            <span class="pac-chevron" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
            </span>
          </label>
          <div class="pac-body" id="pac1-body">
            <div class="pac-body-inner">
              <p class="pac-specs">UV-stabilised polypropylene copolymer tiles, 304.8 × 304.8 mm. Click-lock installation on any flat concrete or asphalt base. Thermal tolerance from −20°C to +60°C. Self-draining grid design suitable for outdoor basketball, volleyball, roller skating, and multi-sport courts.</p>
              <div class="pac-tags">
                <span class="pac-tag">Click-lock assembly</span>
                <span class="pac-tag">Self-draining</span>
                <span class="pac-tag">No adhesive needed</span>
                <span class="pac-tag">UV-stabilised</span>
              </div>
              <a href="/products/pp-interlocking-tiles" class="pac-link">
                View Product <span class="arrow">→</span>
              </a>
            </div>
          </div>
        </div>

        <!-- ── Panel 2: EPDM ── -->
        <div class="pac-panel reveal reveal-delay-2" role="listitem">
          <input type="checkbox" id="pac2" class="pac-toggle" aria-hidden="true" />
          <label class="pac-header" for="pac2" role="button" aria-expanded="false" aria-controls="pac2-body">
            <span class="pac-icon pac-icon--blue" aria-hidden="true">
              <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="20" cy="20" rx="17" ry="11" fill="#2077B4" opacity="0.12" stroke="#2077B4" stroke-width="1.5"/>
                <ellipse cx="20" cy="20" rx="11" ry="6" fill="none" stroke="#2077B4" stroke-width="1" stroke-dasharray="2 1.5" opacity="0.5"/>
                <ellipse cx="20" cy="20" rx="14" ry="8.8" fill="none" stroke="#2077B4" stroke-width="0.8" opacity="0.4"/>
                <line x1="20" y1="9" x2="20" y2="31" stroke="#2077B4" stroke-width="1.2" opacity="0.6"/>
                <circle cx="8" cy="20" r="1" fill="#2077B4" opacity="0.5"/>
                <circle cx="32" cy="20" r="1" fill="#2077B4" opacity="0.5"/>
                <circle cx="20" cy="32" r="1" fill="#2077B4" opacity="0.5"/>
                <circle cx="20" cy="8" r="1.2" fill="#2077B4" opacity="0.8"/>
                <circle cx="12" cy="13" r="0.8" fill="#2077B4" opacity="0.4"/>
                <circle cx="28" cy="13" r="0.8" fill="#2077B4" opacity="0.4"/>
                <circle cx="12" cy="27" r="0.8" fill="#2077B4" opacity="0.4"/>
                <circle cx="28" cy="27" r="0.8" fill="#2077B4" opacity="0.4"/>
              </svg>
            </span>
            <span class="pac-title-wrap">
              <span class="pac-eyebrow">Surface System 02</span>
              <span class="pac-title">EPDM Rubberised Tracks &amp; Surfaces</span>
            </span>
            <span class="pac-chevron" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
            </span>
          </label>
          <div class="pac-body" id="pac2-body">
            <div class="pac-body-inner">
              <p class="pac-specs">Virgin EPDM granules bonded with polyurethane MDI binder. Available in three system configurations: Full-Pour (8–13 mm), Sandwich, and Spray-Coat. Colour-retentive outdoors for 8–10 years under Indian UV conditions. Applied to athletic running tracks, school playgrounds, and recreational zones.</p>
              <div class="pac-tags">
                <span class="pac-tag">Full-pour / Sandwich / Spray</span>
                <span class="pac-tag">Virgin EPDM, not recycled</span>
                <span class="pac-tag">8–10 yr UV durability</span>
                <span class="pac-tag">IAAF-compatible spec</span>
              </div>
              <a href="/products/epdm-tracks-surfaces" class="pac-link">
                View Product <span class="arrow">→</span>
              </a>
            </div>
          </div>
        </div>

        <!-- ── Panel 3: Acrylic ── -->
        <div class="pac-panel reveal reveal-delay-3" role="listitem">
          <input type="checkbox" id="pac3" class="pac-toggle" aria-hidden="true" />
          <label class="pac-header" for="pac3" role="button" aria-expanded="false" aria-controls="pac3-body">
            <span class="pac-icon pac-icon--green" aria-hidden="true">
              <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="6" width="32" height="28" rx="1.5" fill="#5BBE0F" opacity="0.12" stroke="#5BBE0F" stroke-width="1.5"/>
                <line x1="4" y1="20" x2="36" y2="20" stroke="#5BBE0F" stroke-width="1.8"/>
                <line x1="20" y1="6" x2="20" y2="34" stroke="#5BBE0F" stroke-width="1" opacity="0.6"/>
                <line x1="8" y1="14" x2="32" y2="14" stroke="#5BBE0F" stroke-width="0.9" opacity="0.55"/>
                <line x1="8" y1="26" x2="32" y2="26" stroke="#5BBE0F" stroke-width="0.9" opacity="0.55"/>
                <line x1="8" y1="6" x2="8" y2="34" stroke="#5BBE0F" stroke-width="0.9" opacity="0.4"/>
                <line x1="32" y1="6" x2="32" y2="34" stroke="#5BBE0F" stroke-width="0.9" opacity="0.4"/>
                <circle cx="4" cy="20" r="1.5" fill="#5BBE0F" opacity="0.9"/>
                <circle cx="36" cy="20" r="1.5" fill="#5BBE0F" opacity="0.9"/>
              </svg>
            </span>
            <span class="pac-title-wrap">
              <span class="pac-eyebrow">Surface System 03</span>
              <span class="pac-title">Acrylic Court Coating Systems</span>
            </span>
            <span class="pac-chevron" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
            </span>
          </label>
          <div class="pac-body" id="pac3-body">
            <div class="pac-body-inner">
              <p class="pac-specs">Water-based polymer coating system in 5-layer (non-cushion) and 8-layer (premium cushion) configurations. ITF pace-classified for tennis. Applied over existing or new concrete and asphalt courts. Ready for play in 24–48 hours. Suitable for tennis, basketball, badminton, and multi-sport markings.</p>
              <div class="pac-tags">
                <span class="pac-tag">ITF pace-classified</span>
                <span class="pac-tag">5-layer or 8-layer</span>
                <span class="pac-tag">Over concrete or asphalt</span>
                <span class="pac-tag">24–48 hr cure</span>
              </div>
              <a href="/products/acrylic-court-systems" class="pac-link">
                View Product <span class="arrow">→</span>
              </a>
            </div>
