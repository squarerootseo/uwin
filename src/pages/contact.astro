            <div style="grid-column: 1 / -1;">
              <label style="display:block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: #475569;">Full Name *</label>
              <input type="text" name="name" required style="width: 100%; padding: 14px 16px; border: 1px solid #cbd5e1; border-radius: 8px; font-family: inherit; font-size: 1rem; transition: border-color 0.2s;" onfocus="this.style.borderColor='var(--color-primary)'; this.style.outline='none';" onblur="this.style.borderColor='#cbd5e1';">
            </div>
            
            <div>
              <label style="display:block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: #475569;">Company Name *</label>
              <input type="text" name="company" required style="width: 100%; padding: 14px 16px; border: 1px solid #cbd5e1; border-radius: 8px; font-family: inherit; font-size: 1rem; transition: border-color 0.2s;" onfocus="this.style.borderColor='var(--color-primary)'; this.style.outline='none';" onblur="this.style.borderColor='#cbd5e1';">
            </div>
            
            <div>
              <label style="display:block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: #475569;">Designation *</label>
              <input type="text" name="role" required style="width: 100%; padding: 14px 16px; border: 1px solid #cbd5e1; border-radius: 8px; font-family: inherit; font-size: 1rem; transition: border-color 0.2s;" onfocus="this.style.borderColor='var(--color-primary)'; this.style.outline='none';" onblur="this.style.borderColor='#cbd5e1';">
            </div>
            
            <div>
              <label style="display:block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: #475569;">Project Type *</label>
              <select name="project_type" required style="width: 100%; padding: 14px 16px; border: 1px solid #cbd5e1; border-radius: 8px; font-family: inherit; font-size: 1rem; background: white; cursor: pointer; transition: border-color 0.2s;" onfocus="this.style.borderColor='var(--color-primary)'; this.style.outline='none';" onblur="this.style.borderColor='#cbd5e1';">
                <option value="">Select...</option>
                <option value="Basketball">Basketball</option>
                <option value="Tennis">Tennis</option>
                <option value="Running Track">Running Track</option>
                <option value="Playground">Playground</option>
                <option value="Volleyball">Volleyball</option>
                <option value="Multi-Sport">Multi-Sport</option>
                <option value="Other">Other</option>
              </select>
            </div>
            
            <div>
              <label style="display:block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: #475569;">Dimensions (sqm/ft) *</label>
              <input type="text" name="dimensions" required style="width: 100%; padding: 14px 16px; border: 1px solid #cbd5e1; border-radius: 8px; font-family: inherit; font-size: 1rem; transition: border-color 0.2s;" onfocus="this.style.borderColor='var(--color-primary)'; this.style.outline='none';" onblur="this.style.borderColor='#cbd5e1';">
            </div>

            <div style="grid-column: 1 / -1;">
              <label style="display:block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: #475569;">Location (City + State) *</label>
              <input type="text" name="location" required style="width: 100%; padding: 14px 16px; border: 1px solid #cbd5e1; border-radius: 8px; font-family: inherit; font-size: 1rem; transition: border-color 0.2s;" onfocus="this.style.borderColor='var(--color-primary)'; this.style.outline='none';" onblur="this.style.borderColor='#cbd5e1';">
            </div>
            
            <div style="grid-column: 1 / -1;">
              <label style="display:block; margin-bottom: 8px; font-weight: 600; font-size: 14px; color: #475569;">Sub-base Condition *</label>
              <select name="subbase" required style="width: 100%; padding: 14px 16px; border: 1px solid #cbd5e1; border-radius: 8px; font-family: inherit; font-size: 1rem; background: white; cursor: pointer; transition: border-color 0.2s;" onfocus="this.style.borderColor='var(--color-primary)'; this.style.outline='none';" onblur="this.style.borderColor='#cbd5e1';">
